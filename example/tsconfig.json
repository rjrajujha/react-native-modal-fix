{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": false,
    "jsx": "react",
    "lib": ["es6"],
    "moduleResolution": "node",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "react-native-modal-fix": ["../src/index"]
    },
    "strict": false,
    "target": "esnext",
    "resolveJsonModule": true
  }
}
